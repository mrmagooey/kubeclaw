# NanoClaw Environment Configuration

# =============================================================================
# Core Configuration
# =============================================================================

# Assistant name (used for trigger mentions like @AssistantName)
ASSISTANT_NAME=Andy

# Whether the assistant has its own phone number (for WhatsApp)
ASSISTANT_HAS_OWN_NUMBER=false

# Log level (debug, info, warn, error, fatal)
LOG_LEVEL=info

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Default LLM provider: 'claude' or 'openrouter'
DEFAULT_LLM_PROVIDER=claude

# --- Claude Configuration ---
# One of the following authentication methods is required:
CLAUDE_CODE_OAUTH_TOKEN=              # Claude Code OAuth token
ANTHROPIC_API_KEY=sk-ant-...          # Anthropic API key (alternative)
ANTHROPIC_BASE_URL=                   # Optional: Custom base URL
ANTHROPIC_AUTH_TOKEN=                 # Optional: Auth token

# --- OpenRouter Configuration ---
# Required if using OpenRouter as default or per-group provider:
OPENROUTER_API_KEY=sk-or-v1-...       # Your OpenRouter API key
OPENROUTER_MODEL=openai/gpt-4o        # Model to use (default: openai/gpt-4o)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1  # API base URL (optional)
OPENROUTER_HTTP_REFERER=              # Your domain (optional, for rankings)
OPENROUTER_X_TITLE=NanoClaw           # App name (optional, for rankings)

# =============================================================================
# Container Configuration
# =============================================================================

# Container images (defaults are set automatically)
# CLAUDE_CONTAINER_IMAGE=nanoclaw-agent:claude
# OPENROUTER_CONTAINER_IMAGE=nanoclaw-agent:openrouter

# Container timeout in milliseconds (default: 1800000 = 30 min)
CONTAINER_TIMEOUT=1800000

# Maximum container output size in bytes (default: 10485760 = 10MB)
CONTAINER_MAX_OUTPUT_SIZE=10485760

# Maximum concurrent containers (default: 5)
MAX_CONCURRENT_CONTAINERS=5

# Idle timeout in milliseconds (default: 1800000 = 30 min)
IDLE_TIMEOUT=1800000

# =============================================================================
# Runtime Mode Configuration
# =============================================================================

# Runtime mode: 'docker' or 'kubernetes'
NANOCLAW_RUNTIME=docker

# --- Kubernetes Configuration (only needed if NANOCLAW_RUNTIME=kubernetes) ---
# REDIS_URL=redis://localhost:6379
# NANOCLAW_NAMESPACE=default
# NANOCLAW_IPC_BASE=/tmp/nanoclaw-ipc
# MAX_CONCURRENT_JOBS=10
# AGENT_JOB_MEMORY_REQUEST=512Mi
# AGENT_JOB_MEMORY_LIMIT=4Gi
# AGENT_JOB_CPU_REQUEST=250m
# AGENT_JOB_CPU_LIMIT=2000m

# =============================================================================
# Timezone Configuration
# =============================================================================

# Timezone for scheduled tasks (defaults to system timezone)
# TZ=America/New_York

# =============================================================================
# WhatsApp Configuration (if using WhatsApp channel)
# =============================================================================

# WHATSAPP_SESSION_PATH=./whatsapp-session

# =============================================================================
# Telegram Configuration (if using Telegram channel)
# =============================================================================

# TELEGRAM_BOT_TOKEN=your_bot_token_here

# =============================================================================
# Slack Configuration (if using Slack channel)
# =============================================================================

# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your-signing-secret
# SLACK_APP_TOKEN=xapp-your-app-token (for Socket Mode)

# Added by skill
IRC_SERVER=
IRC_PORT=
IRC_NICK=
IRC_CHANNELS=

# =============================================================================
# Redis ACL Configuration (for sidecar follow-up support)
# =============================================================================

# Redis admin password for ACL management (required for K8s sidecar mode)
# Generate a strong password for production
# REDIS_ADMIN_PASSWORD=your-secure-redis-admin-password

# Encryption key for ACL credentials at rest (32+ bytes recommended)
# If not set, a derived key will be used (INSECURE - for development only)
# ACL_ENCRYPTION_KEY=your-32-byte-encryption-key-here!!!
