# E2E Testing Environment Variables
# 
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
#

# =============================================================================
# Core Configuration
# =============================================================================

# Node environment (development, test, production)
NODE_ENV=test

# Enable debug logging
DEBUG=false

# Test phase to run (all, phase-1, phase-2, phase-3)
TEST_PHASE=all

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection URL
# Format: redis://[username:password@]host:port[/database]
REDIS_URL=redis://localhost:6379

# Redis password (if authentication is enabled)
REDIS_PASSWORD=

# =============================================================================
# Kubernetes Configuration
# =============================================================================

# Runtime environment (docker, kubernetes)
KUBECLAW_RUNTIME=kubernetes

# Kubernetes namespace
KUBECLAW_NAMESPACE=kubeclaw

# Path to kubeconfig file
KUBECONFIG=~/.kube/config

# Maximum concurrent jobs
MAX_CONCURRENT_JOBS=10

# =============================================================================
# Minikube Configuration
# =============================================================================

# Minikube driver (docker, virtualbox, kvm2, hyperkit, hyperv)
MINIKUBE_DRIVER=docker

# Memory allocated to minikube (MB)
MINIKUBE_MEMORY=4096

# CPUs allocated to minikube
MINIKUBE_CPUS=2

# Kubernetes version for minikube
MINIKUBE_KUBERNETES_VERSION=v1.29.0

# =============================================================================
# API Keys and Secrets
# =============================================================================

# Anthropic API Key for agent execution
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# Claude Code OAuth Token (optional)
# Used for advanced agent features
CLAUDE_CODE_OAUTH_TOKEN=

# =============================================================================
# Container Images
# =============================================================================

# Orchestrator image name and tag
ORCHESTRATOR_IMAGE=kubeclaw-orchestrator:latest

# Agent image name and tag
AGENT_IMAGE=kubeclaw-agent:latest

# Registry for pulling images (optional)
# DOCKER_REGISTRY=your-registry.com

# =============================================================================
# Test Configuration
# =============================================================================

# Timeout for individual tests (milliseconds)
TEST_TIMEOUT=60000

# Timeout for test suite (milliseconds)
SUITE_TIMEOUT=300000

# Number of test retries on failure
TEST_RETRIES=2

# Parallel test workers
TEST_WORKERS=2

# Enable test coverage reporting
COVERAGE=false

# =============================================================================
# CI/CD Configuration
# =============================================================================

# Running in CI environment
CI=false

# Clean up resources after tests
CLEANUP_ON_EXIT=true

# Generate JUnit XML reports
GENERATE_JUNIT=true

# Generate Markdown reports
GENERATE_MARKDOWN=true

# =============================================================================
# Notification Webhooks
# =============================================================================

# Slack webhook URL for notifications
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Discord webhook URL for notifications
# Create one in your Discord server settings
DISCORD_WEBHOOK_URL=

# =============================================================================
# Artifact and Logging
# =============================================================================

# Directory for test results
RESULTS_DIR=./e2e/results

# Directory for test logs
LOGS_DIR=./e2e/logs

# Retention days for artifacts
ARTIFACT_RETENTION_DAYS=7

# =============================================================================
# Network Configuration
# =============================================================================

# Base domain for services
BASE_DOMAIN=localhost

# Port for orchestrator service
ORCHESTRATOR_PORT=3000

# Port for Redis service
REDIS_PORT=6379

# =============================================================================
# Security
# =============================================================================

# Enable network policies
ENABLE_NETWORK_POLICIES=false

# Enable pod security policies
ENABLE_PSP=false

# RBAC configuration
ENABLE_RBAC=true

# =============================================================================
# Advanced Options
# =============================================================================

# Skip building images (use existing)
SKIP_BUILD=false

# Force rebuild images
FORCE_BUILD=false

# Use cache for builds
USE_BUILD_CACHE=true

# Enable Docker BuildKit
DOCKER_BUILDKIT=1

# Build platform (linux/amd64, linux/arm64)
BUILD_PLATFORM=linux/amd64
