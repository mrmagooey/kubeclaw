# Minikube Configuration
MINIKUBE_DRIVER=docker
MINIKUBE_CPUS=4
MINIKUBE_MEMORY=8192
MINIKUBE_DISK_SIZE=40g
MINIKUBE_KUBERNETES_VERSION=stable

# Test Timeouts (in seconds)
TEST_TIMEOUT_SHORT=30
TEST_TIMEOUT_MEDIUM=120
TEST_TIMEOUT_LONG=300
TEST_TIMEOUT_JOB_COMPLETION=180

# Image Names
NANOCLAW_AGENT_IMAGE=nanoclaw-agent:latest
NANOCLAW_ORCHESTRATOR_IMAGE=nanoclaw-orchestrator:latest
REDIS_IMAGE=redis:7-alpine

# Test Configuration
TEST_NAMESPACE=nanoclaw
TEST_PVC_SIZE=1Gi
TEST_JOB_TTL_SECONDS=60

# Resource Limits for Tests
TEST_CPU_REQUEST=100m
TEST_CPU_LIMIT=500m
TEST_MEMORY_REQUEST=128Mi
TEST_MEMORY_LIMIT=512Mi

# E2E Test Settings
E2E_CLEANUP_AFTER_TEST=true
E2E_KEEP_FAILED_RESOURCES=false
E2E_VERBOSE_OUTPUT=true

# Redis Configuration
REDIS_URL=redis://nanoclaw-redis:6379
REDIS_CHANNEL_PREFIX=nanoclaw:test

# Network Test Endpoints
EXTERNAL_TEST_HOST=example.com
EXTERNAL_TEST_PORT=443
INTERNAL_TEST_HOST=nanoclaw-redis
INTERNAL_TEST_PORT=6379

# Container Registry (for CI/CD)
CONTAINER_REGISTRY=localhost:5000
PUSH_IMAGES_TO_REGISTRY=false
