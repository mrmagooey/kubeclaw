{
  "name": "kubeclaw",
  "version": "1.2.10",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "setup:minikube": "tsx setup/minikube.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts",
    "test:e2e:phase-1": "vitest run --config vitest.e2e.config.ts --testNamePattern='Phase 1'",
    "test:e2e:phase-2": "vitest run --config vitest.e2e.config.ts --testNamePattern='Phase 2'",
    "test:e2e:phase-3": "vitest run --config vitest.e2e.config.ts --testNamePattern='Phase 3'",
    "test:e2e:ci": "cd e2e && make test-ci",
    "test:e2e:report": "cd e2e && make report",
    "test:e2e:setup": "cd e2e && make setup",
    "test:e2e:cleanup": "cd e2e && make cleanup"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cron-parser": "^5.5.0",
    "ioredis": "^5.6.0",
    "irc-upd": "^0.11.0",
    "openai": "^6.32.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "sql.js": "^1.11.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/sql.js": "^1.4.9",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^11.8.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
