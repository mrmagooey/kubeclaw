{
  "name": "nanoclaw-file-adapter",
  "version": "1.0.0",
  "description": "NanoClaw file-based sidecar adapter for arbitrary containers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^1.6.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0"
  }
}
